Project placamia {
  database_type: "PostgreSQL"
  Note: "Current PlacamIA backend schema generated from SQLAlchemy models."
}

Table users {
  id integer [pk, increment]
  email varchar(255) [not null, unique]
  full_name varchar(255)
  role varchar(32) [not null, default: "user"]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_users_id"]
    email [unique, name: "ix_users_email"]
  }
}

Table audit_logs {
  id integer [pk, increment]
  actor_user_id integer [not null]
  action varchar(100) [not null]
  resource_type varchar(100) [not null]
  resource_id varchar(100)
  event_details json [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_audit_logs_id"]
    actor_user_id [name: "ix_audit_logs_actor_user_id"]
    action [name: "ix_audit_logs_action"]
    resource_type [name: "ix_audit_logs_resource_type"]
  }
}

Ref: audit_logs.actor_user_id > users.id

Table categories {
  id integer [pk, increment]
  name varchar(255) [not null, unique]
  description text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_categories_id"]
    name [unique, name: "ix_categories_name"]
  }
}

Table products {
  id integer [pk, increment]
  name varchar(255) [not null]
  description text
  category_id integer [not null]
  base_price numeric(10, 2) [not null]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_products_id"]
    name [name: "ix_products_name"]
    category_id [name: "ix_products_category_id"]
  }
}

Ref: products.category_id > categories.id

Table templates {
  id integer [pk, increment]
  name varchar(255) [not null]
  description text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_templates_id"]
    name [name: "ix_templates_name"]
  }
}

Table template_fields {
  id integer [pk, increment]
  template_id integer [not null]
  field_name varchar(255) [not null]
  field_type varchar(100) [not null]
  is_required boolean [not null, default: false]
  allowed_values json
  display_order integer [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_template_fields_id"]
    template_id [name: "ix_template_fields_template_id"]
    field_name [name: "ix_template_fields_field_name"]
  }
}

Ref: template_fields.template_id > templates.id

Table designs {
  id integer [pk, increment]
  template_id integer [not null]
  customization_values json [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_designs_id"]
    template_id [name: "ix_designs_template_id"]
  }
}

Ref: designs.template_id > templates.id

Table kits {
  id integer [pk, increment]
  name varchar(255) [not null]
  description text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_kits_id"]
    name [name: "ix_kits_name"]
  }
}

Table kit_items {
  id integer [pk, increment]
  kit_id integer [not null]
  product_id integer [not null]
  quantity integer [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    id [name: "ix_kit_items_id"]
    kit_id [name: "ix_kit_items_kit_id"]
    product_id [name: "ix_kit_items_product_id"]
  }
}

Ref: kit_items.kit_id > kits.id
Ref: kit_items.product_id > products.id
