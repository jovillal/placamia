APP_NAME=PlacamIA API
ENV=local

DB_HOST=localhost
DB_PORT=54322
DB_NAME=placamia
DB_USER=placamia
DB_PASSWORD=placamia

DATABASE_URL=postgresql://placamia:placamia@localhost:54322/placamia
SQLALCHEMY_ECHO=false
AUTH_TOKEN_SECRET=change-me-local-auth-token-secret
PAYMENT_WEBHOOK_SECRET=change-me-local-payment-webhook-secret
PAYMENT_PROVIDER_DEFAULT=wompi
PAYMENT_RETURN_URL=http://localhost:3000/payments/return
PAYMENT_CHECKOUT_TTL_SECONDS=1800
WOMPI_ENVIRONMENT=sandbox
WOMPI_PUBLIC_KEY=pub_test_replace-with-sandbox-public-key
WOMPI_INTEGRITY_SECRET=test_integrity_replace-with-sandbox-integrity-secret
